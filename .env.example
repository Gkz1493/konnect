# KONNECT — Environment Variables
# Copy to .env.local and fill in. Without these the app runs in Demo Mode (mock data, no persistence).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Payments (production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
